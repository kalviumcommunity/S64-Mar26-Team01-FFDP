rules_version = '2';

// NanheNest — Firestore Security Rules
// Principle: deny everything by default, allow only what is explicitly permitted.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Returns true if the request comes from a signed-in user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the signed-in user's UID matches the document owner
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── users/{uid} ─────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (for social features).
    // Only the document owner can write their own profile.
    match /users/{uid} {
      allow read:  if isAuthenticated();
      allow write: if isOwner(uid);

      // items subcollection — full CRUD, owner only (Assignment 3.42)
      match /items/{itemId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── posts/{postId} ──────────────────────────────────────────────────────
    // Any authenticated user can read posts.
    // Any authenticated user can create a post (uid must match their own).
    // Only the post author can update or delete their post.
    match /posts/{postId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update,
            delete: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;

      // comments subcollection — any authenticated user can read/create,
      // only the comment author can delete
      match /comments/{commentId} {
        allow read:   if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated()
                      && resource.data.uid == request.auth.uid;
      }

      // likes subcollection — document ID is the liker's UID (prevents duplicates)
      match /likes/{likerUid} {
        allow read:   if isAuthenticated();
        allow write:  if isOwner(likerUid);
      }
    }

    // ── tasks/{taskId} ──────────────────────────────────────────────────────
    // Used by Firestore Write/Query demo screens.
    // Any authenticated user can read all tasks.
    // Only the task creator can update or delete their task.
    match /tasks/{taskId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update,
            delete: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;
    }

    // ── events/{eventId} ────────────────────────────────────────────────────
    // Any authenticated user can read events and RSVP (update attendees).
    // Only the event creator can delete or fully update the event.
    match /events/{eventId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAuthenticated();   // allows RSVP by any user
      allow delete: if isAuthenticated()
                    && resource.data.creatorUid == request.auth.uid;
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
