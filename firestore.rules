rules_version = '2';

// NanheNest — Firestore Security Rules
// Updated for Babysitter Marketplace Schema

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Returns true if the request comes from a signed-in user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the signed-in user's UID matches the given uid
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── users/{uid} ─────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read profiles (Needed for Map/Search)
      // EXCEPT the verification map
      allow read: if isAuthenticated();
      
      // Only the owner can write their own profile
      allow write: if isOwner(uid);
    }

    // ── jobs/{jobId} ──────────────────────────────────────────────────────
    match /jobs/{jobId} {
      // A job can only be read or written by the specific parent or babysitter involved
      allow read, write: if isAuthenticated() 
                         && (resource.data.parentId == request.auth.uid 
                             || resource.data.babysitterId == request.auth.uid
                             || request.resource.data.parentId == request.auth.uid);
    }

    // ── reviews/{reviewId} ──────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone can read reviews to see a babysitter's ratings
      allow read: if isAuthenticated();
      
      // Only an authenticated parent can write a review about a babysitter
      allow create: if isAuthenticated()
                    && request.resource.data.parentId == request.auth.uid;
                    
      // Reviews cannot be modified once created
      allow update, delete: if false;
    }

    // ── chats/{chatId} & messages ──────────────────────────────────────────
    match /chats/{chatId} {
      // A user can read/write chats if they are in the participants array
      allow read, write: if isAuthenticated() 
                         && request.auth.uid in resource.data.participants;
                         
      match /messages/{messageId} {
        allow read: if isAuthenticated() 
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() 
                      && request.auth.uid == request.resource.data.senderId;
      }
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}